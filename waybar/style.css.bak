@define-color bg rgba(0, 0, 0, 0.5);
@define-color mod-fg rgba(0, 0, 0, 1);
@define-color mod-bg rgba(163, 160, 157, 1);

* {
    font-family: "SF UI Text", "Cousine Nerd Font Propo";
    font-weight: bold;
    font-size: 13px;
    min-height: 0px;
    margin: 0px;
    padding: 0px;
}

window#waybar {
    background-color: @bg;
    color: #ffffff;
    transition-property: background-color;
    transition-duration: .5s;
}

window#waybar.hidden {
    opacity: 0.2;
}

/*
window#waybar.empty {
    background-color: transparent;
}
window#waybar.solo {
    background-color: #FFFFFF;
}
*/

window#waybar.termite {
    background-color: #3F3F3F;
}

window#waybar.chromium {
    background-color: #000000;
    border: none;
}

button {
    /* Use box-shadow instead of border so the text isn't offset */
    box-shadow: inset 0 -3px transparent;
    /* Avoid rounded borders under each button name */
    border: none;
    border-radius: 0;
}

#workspaces button {
    padding: 0 5px;
    background-color: transparent;
    color: #ffffff;
}

#workspaces button:hover {
    background: rgba(0, 0, 0, 0.2);
}

#workspaces button.focused, #workspaces button.active {
    background-color: @mod-bg;
    color: @mod-fg;
}

#workspaces button.urgent {
    background-color: #eb4d4b;
}

#mode {
    background-color: #64727D;
    box-shadow: inset 0 -3px #ffffff;
}

#custom-rofi {
  background-color: @mod-bg;
  color: @mod-fg;
  margin: 4px 0px;
  padding: 0px 8px;
  border-radius: 2px;
}

#clock,
#pulseaudio,
#tray,
#mpd {
    padding: 0 10px;
    margin: 4px 0px;
    color: @mod-fg;
    background-color: @mod-bg;
    border-radius: 4px;
    transition: all 0.3s cubic-bezier(.4, 0, .2, 1);
}

#mpris {
    border-radius: 4px;
    padding: 0px 8px;
    margin: 4px 0;
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1), color 0.5s ease;
}

#mpris.playing {
    color: @mod-bg;
}

#mpris.paused {
    color: @mod-fg;
    background-color: @mod-bg;
}

#custom-brightness {
    padding: 0 6px;
    margin: 4px 0px;
    color: @mod-fg;
    background-color: @mod-bg;
    border-radius: 4px;
    transition: all 0.3s cubic-bezier(.4, 0, .2, 1);
}

#tray menu,
#tray menuitem,
#custom-power menu {
  margin: 0px;
  padding: 4px 0px;
  border-radius: 8px;
}

#custom-power,
#pulseaudio.muted {
  background-color: @transparent;
  color: white;
  padding: 0 10px;
  margin: 4px 0px;
  border-radius: 4px;
  transition: all 0.3s cubic-bezier(.4, 0, .2, 1);
}

#custom-power:hover,
#pulseaudio.muted:hover {
  background-color: rgba(0, 0, 0, 0.2);
  color: white;
  padding: 0 10px;
  margin: 4px 0px;
  border-radius: 4px;
  transition: all 0.3s cubic-bezier(.4, 0, .2, 1);
}

#clock:hover,
#custom-brightness:hover,
#pulseaudio:hover,
#custom-power:hover,
#tray:hover {
  background-color: @transparent;
  color: white;
}

#window {
    margin: 0 4px;
}

#workspaces button {
    color: #ffffff;
    margin: 4px 0px;      /* Creates a gap between buttons */
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(.4, 0, .2, 1);
}

/* If workspaces is the leftmost module, omit left margin */
.modules-left > widget:first-child > #custom-rofi {
    margin-left: 4px;
}

/* If workspaces is the rightmost module, omit right margin */
.modules-right > widget:last-child > #custom-power {
    margin-right: 4px;
}
